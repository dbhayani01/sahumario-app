# Payment Gateway Configuration
REACT_APP_RAZORPAY_KEY_ID=your_razorpay_key_id_here

# GitHub Integration for Admin Product Management
# Create a Personal Access Token at: https://github.com/settings/tokens
# Required scopes: repo (Full control of private repositories)
REACT_APP_GITHUB_TOKEN=your_github_personal_access_token
REACT_APP_GITHUB_OWNER=your_github_username
REACT_APP_GITHUB_REPO=your_repository_name
REACT_APP_GITHUB_BRANCH=main

# Security Notes:
# 1. Never commit the actual .env file to version control
# 2. Add .env to your .gitignore file
# 3. For production, use environment variables in your hosting platform
# 4. Consider using a backend API instead of direct GitHub commits from frontend
